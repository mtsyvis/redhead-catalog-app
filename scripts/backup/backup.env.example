# Copy this file to /etc/redhead/backup.env on the VPS.
# Do not commit the real /etc/redhead/backup.env file.

APP_DIR="/opt/readhead-catalog/app"
BACKUP_DIR="/var/backups/redhead/postgres"
LOG_FILE="/var/log/redhead-postgres-backup.log"

COMPOSE_SERVICE="postgres"
DB_USER="postgres"
DB_NAME="redhead_sites_catalog"

RCLONE_REMOTE_PATH="redhead-tech-backups:PostgreSQL"

FILE_PREFIX="redhead-prod-postgres"

# Keep local temporary backup files for quick access.
LOCAL_RETENTION_DAYS="7"

# Keep Google Drive backup files for this many days.
REMOTE_RETENTION_DAYS="30"
