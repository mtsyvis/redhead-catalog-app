# Copy to .env and set values. Do not commit .env.
# Connection string (app uses key "DefaultConnection")
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=redhead_sites_catalog;Username=postgres;Password=CHANGE_ME

# Seed SuperAdmin (required for first run; password must meet complexity: digit, lower, upper, non-alphanumeric)
SEED_SUPERADMIN_EMAIL=superadmin@redhead.com
SEED_SUPERADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Optional: override in production
# ASPNETCORE_ENVIRONMENT=Production
# ASPNETCORE_URLS=http://+:8080

# Google Drive API credentials (required for Google Drive integration)
GOOGLE_DRIVE_CLIENT_ID=...
GOOGLE_DRIVE_CLIENT_SECRET=...
GOOGLE_DRIVE_REDIRECT_URI=https://example.com/api/integrations/google-drive/callback
GOOGLE_DRIVE_APP_NAME=Redhead Catalog
GOOGLE_DRIVE_EXPORT_FOLDER_NAME=Redhead Catalog Exports
FRONTEND_BASE_URL=https://example.com

# Weekly emergency Sites export to a Google Shared Drive folder (disabled unless explicitly enabled)
EmergencySitesExport__Enabled=false
EmergencySitesExport__ScheduleCron=30 3 * * MON
EmergencySitesExport__GoogleDriveFolderId=
EmergencySitesExport__ServiceAccountJsonPath=/run/secrets/google-service-account.json
EmergencySitesExport__RetentionWeeks=8
EmergencySitesExport__FilePrefix=redhead-sites-full
